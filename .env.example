# =====================================================================
# Shared development environment template.
# Copy to .env (root) and to each app's .env.local as needed.
#
# SECURITY:
#   - NEVER commit a real .env. The repo .gitignore enforces this.
#   - Any value containing "replace_me" or "your-instance" is rejected
#     by validate_production_secrets() at boot when API_ENV=production.
#   - See docs/security/SECRETS.md for rotation procedures.
# =====================================================================

# ---- Environment ----
API_ENV=development                       # development | staging | production
API_LOG_LEVEL=INFO
API_VERSION=0.0.0
API_CORS_ORIGINS=http://localhost:3000    # comma-separated origins

# ---- Database ----
DATABASE_URL=postgresql+psycopg://aicmo:aicmo@localhost:5432/aicmo

# ---- Redis / job queue ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth mode ----
# demo   = no Clerk verification anywhere (dev only)
# clerk  = strict — every request must carry a valid Clerk JWT
# hybrid = anonymous → demo user; Bearer → verified Clerk user
# Production MUST be 'clerk'. validate_production_secrets() refuses to
# boot if API_ENV=production and AUTH_MODE != 'clerk'.
AUTH_MODE=hybrid

# ---- Clerk auth ----
# Get from https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# When set, JWT audience verification is enabled. Required in production.
# Leave empty in dev to preserve the prior verify_aud=False behaviour.
CLERK_JWT_AUDIENCE=
# Clerk webhook (Svix) — format: whsec_<base64>. Empty disables webhook (503).
CLERK_WEBHOOK_SIGNING_SECRET=

# ---- LLM providers ----
# Default LLM for content/ad generation is Anthropic Claude Sonnet 4.6.
ANTHROPIC_API_KEY=sk-ant-replace_me
OPENAI_API_KEY=sk-replace_me
GOOGLE_API_KEY=replace_me

LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# ---- Lead-capture security ----
# Cloudflare Turnstile site + secret keys. Empty in dev = bypass.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Pepper for SHA-256 IP hashing (GDPR — never store raw IPs). REQUIRED in prod.
IP_HASH_PEPPER=
LEAD_CAPTURE_RATE_LIMIT=5
PUBLIC_BASE_URL=http://localhost:3000

# ---- Media / image rendering ----
MEDIA_DIR=./media
# HMAC key for signed media URLs. REQUIRED in prod (no clerk fallback).
MEDIA_SIGNING_SECRET=
IMAGE_RENDER_DAILY_CAP=20

# ---- Social-1: read-only Instagram OAuth ----
IG_CLIENT_ID=
IG_CLIENT_SECRET=

# Google Business Profile OAuth (reviews, calls, directions, profile views)
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=

# ---- Integration token encryption (Phase 10.2a) ----
# Fernet key (base64, 44 chars). REQUIRED before connecting any provider.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_TOKEN_KEY=

# ---- Billing / Stripe (Phase 1) ----
# Both flags default OFF — billing ships dark. Plan prices + quotas live
# in the DB (plan / plan_quota tables), NOT here — tune them with SQL.
BILLING_LIVE_ENABLED=false        # true → /checkout + /portal hit Stripe
BILLING_ENFORCE_LIMITS=false      # true → quota gate can block over-limit (record-only when false)
# Required ONLY when BILLING_LIVE_ENABLED=true (validated at boot in prod).
STRIPE_SECRET_KEY=                # sk_test_... / sk_live_...
STRIPE_WEBHOOK_SECRET=            # whsec_...  (from the Stripe webhook endpoint)

# ---- Creative Platform / Video (Creative Core V0) ----
# Ships DARK. video_enabled=false → /creative/* returns 409, no pipeline.
# Providers/backend default to no-network stubs/local (no spend).
VIDEO_ENABLED=false
VIDEO_DEFAULT_PROVIDER=stub       # stub | veo3 (veo3 lands in V1)
TTS_DEFAULT_PROVIDER=stub         # stub | elevenlabs
MEDIA_BACKEND=local               # local | s3
VIDEO_RENDER_DAILY_CAP=5          # per user/day (cost-abuse control)
VIDEO_ORG_MONTHLY_BUDGET_CENTS=0  # 0 = use plan default
# Required only when video_enabled=true AND the matching provider/backend is selected:
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=   # path to Vertex service-account JSON
ELEVENLABS_API_KEY=
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=                  # S3-compatible (AWS/R2/MinIO)

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Sentry (A2) ----
# Empty in dev = no Sentry init. Production MUST set SENTRY_DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Source-map upload at build time. Empty = skip upload (dev/local).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
