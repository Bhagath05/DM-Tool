# =====================================================================
# apps/web — Next.js environment template.
# Copy to apps/web/.env.local (gitignored).
#
# NEXT_PUBLIC_* values are baked into the client bundle at build time.
# Treat them as PUBLIC. Anything secret stays unprefixed and server-only.
# =====================================================================

NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Auth mode (must agree with backend AUTH_MODE) ----
NEXT_PUBLIC_AUTH_MODE=hybrid

# ---- Clerk ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---- Sentry (frontend) ----
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Build-time only — used by withSentryConfig for source-map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---- Environment badge (topbar) ----
# Resolved at build time by useTenant().environment.
NEXT_PUBLIC_APP_ENV=development
